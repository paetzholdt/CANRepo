@startuml state_machine_tram

legend left
Produced signals:
    DrivingState:
        - vehicle_stopped

    StopRequestState:
        - stop_request_set
    
    DoorReleaseState:
        - valid_door_release
    
    FallbackDoorReleaseState:
        - valid_fallback_door_release
    
    StationDetectionState:
        - station_detected

    DoorState:
        - doors_closed
        - stop_request_reset_conditions_met


Consumed signals:
    DrivingState:
        - doors_closed
        - valid_door_release
        - valid_fallback_door_release
    
    StopRequestState:
        - stop_request_reset_conditions_met
    
    DoorReleaseState:
        - vehicle_stopped
        - station_detected
    
    FallbackDoorReleaseState:
        - vehicle_stopped
    
    StationDetectionState:
        - none
    
    DoorState:
        - stop_request_set
        - valid_door_release
        - valid_fallback_door_release
        - internal timer event

endlegend


state DrivingState {
    [*] --> Stopped
    state Stopped
    state Moving {
        /'
        [*] --> Accelerating
        state Accelerating
        state Rolling
        state Braking

        Accelerating: traction command applied

        Rolling: traction command idle

        Braking: brake command applied


        Accelerating --> Rolling
        Rolling --> Accelerating
        Rolling --> Braking
        Braking --> Rolling
        '/
    }

    Stopped: output vehicle_stopped = true
    Stopped: vehicle_speed == 0

    Moving: output vehicle_stopped = false
    Moving: vehicle_speed != 0


    Stopped --> Moving : traction_command_applied [doors_closed and !valid_door_release and !valid_fallback_door_release] / apply_traction_command
    Moving --> Stopped : vehicle_speed_reaches_zero / hold_vehicle_at_stop
    
}

--

state StopRequestState {
    [*] --> StopRequest_Reset
    state StopRequest_Reset
    state StopRequest_Set

    StopRequest_Reset: output stop_request_set = false
    StopRequest_Reset: signal light off

    StopRequest_Set: output stop_request_set = true
    StopRequest_Set: signal light on


    StopRequest_Reset --> StopRequest_Set : passenger_stop_button_pressed / activate_acoustic_signal_once
    StopRequest_Set --> StopRequest_Set : passenger_stop_button_pressed / ignore_duplicate_stop_request
    StopRequest_Set --> StopRequest_Reset : stop_request_reset_conditions_met
}

--

state DoorReleaseState {
    [*] --> DoorRelease_Inactive
    state DoorRelease_Inactive
    state DoorRelease_Active

    DoorRelease_Inactive: output valid_door_release = false
    DoorRelease_Inactive: doors are blocked


    DoorRelease_Active: output valid_door_release = true
    DoorRelease_Active: only active inside of station perimeter
    DoorRelease_Active: if tram starts moving or leaves station, validity is immediately lost

    DoorRelease_Inactive --> DoorRelease_Active : door_release_button_set [vehicle_stopped and station_detected]
    DoorRelease_Inactive --> DoorRelease_Inactive : door_release_button_set [!vehicle_stopped or !station_detected] / warn_driver
    DoorRelease_Active --> DoorRelease_Inactive : door_release_button_reset / clear_warning
    DoorRelease_Active --> DoorRelease_Inactive : validity_lost [!vehicle_stopped or !station_detected] / alert_driver
}

--

state FallbackDoorReleaseState {
    [*] --> FallbackDoorRelease_Inactive
    state FallbackDoorRelease_Inactive
    state FallbackDoorRelease_Active

    FallbackDoorRelease_Inactive: output valid_fallback_door_release = false
    FallbackDoorRelease_Inactive: doors are blocked


    FallbackDoorRelease_Active: output valid_fallback_door_release = true
    FallbackDoorRelease_Active: can be active outside of station perimeter
    FallbackDoorRelease_Active: if tram starts moving, validity is immediately lost

    FallbackDoorRelease_Inactive --> FallbackDoorRelease_Active : fallback_door_release_button_set [vehicle_stopped]
    FallbackDoorRelease_Inactive --> FallbackDoorRelease_Inactive : fallback_door_release_button_set [!vehicle_stopped] / warn_driver
    FallbackDoorRelease_Active --> FallbackDoorRelease_Inactive : fallback_door_release_button_reset / clear_warning
    FallbackDoorRelease_Active --> FallbackDoorRelease_Inactive : validity_lost [!vehicle_stopped] / alert_driver

}

--

state StationDetectionState {
    [*] --> No_Station_Detected
    state No_Station_Detected
    state Station_Detected

    No_Station_Detected: output station_detected = false
    No_Station_Detected: vehicle is outside of station perimeter

    Station_Detected: output station_detected = true
    Station_Detected: vehicle is inside of station perimeter along its entire length


    No_Station_Detected --> Station_Detected : station_signal_detected
    Station_Detected --> No_Station_Detected : no_station_signal_detected

}

--

state DoorState {
    [*] --> Doors_Closed
    state Doors_Closed
    /'state Doors_Closing'/
    state Doors_Open
    /'state Doors_Opening'/

    Doors_Closed: output doors_closed = true
    Doors_Closed: output stop_request_reset_conditions_met = false

    Doors_Open: output doors_closed = false
    Doors_Open: output stop_request_reset_conditions_met = true

    Doors_Closed --> Doors_Open : open_door_request [(valid_door_release || valid_fallback_door_release) && stop_request_set] / open_doors; start_timer
    Doors_Open --> Doors_Closed : internal_timer_run_out / close_doors
    Doors_Open --> Doors_Open : open_door_request [(valid_door_release || valid_fallback_door_release) && stop_request_set] / restart_timer
    Doors_Closed --> Doors_Closed : open_door_request [(!valid_door_release && !valid_fallback_door_release) || !stop_request_set]
}

--

/'
state SpringLoadedBrakeState {
    [*] --> SLB_Active
    state SLB_Active
    state SLB_Activating
    state SLB_Releasing
    state SLB_Released

    SLB_Active --> SLB_Releasing
    SLB_Releasing --> SLB_Released
    SLB_Releasing --> SLB_Activating
    SLB_Activating --> SLB_Active
    SLB_Released --> SLB_Activating

    SLB_Active --> SLB_Released : traction_command_applied
    SLB_Released --> SLB_Active : vehicle_speed_reaches_zero [vehicle_speed <= 0]

}


--

state DoorDiagnosticState {
    [*] --> Doors_Operational
    state Doors_Operational
    state Doors_Malfunction

    Doors_Operational --> Doors_Malfunction : Malfunction detected
    Doors_Malfunction --> Doors_Operational : Malfunction resolved
}

--

state PassengerEmergencyBrakeState {
    [*] --> PEB_Inactive
    state PEB_Inactive
    state PEB_Active
}

--

state PassengerEmergencyDoorReleaseState {
    [*] --> PEDR_Inactive
    state PEDR_Inactive
    state PEDR_Active

}

--

'/
@enduml